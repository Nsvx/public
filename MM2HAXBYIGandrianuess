local function safeTeleport(coords)
    local c = LocalPlayer.Character
    if c then
        local r = c:FindFirstChild("HumanoidRootPart")
        if r then r.CFrame = coords * CFrame.new(math.random(-1,1)/10, 0, math.random(-1,1)/10) end
    end
end

local function executeTeleport()
    if not tpActive then return end
    local targetMap = nil
    local mapNames = {"Factory", "MilBase", "Bank2", "Hotel", "House2", "ResearchFacility", "Office3", "PoliceStation", "Mansion2", "Workplace", "BioLab", "Hospital"}
    
    for _, name in ipairs(mapNames) do
        if Workspace:FindFirstChild(name) then targetMap = name break end
    end
    
    if not targetMap then
        detectedMaps = {}
        lastTeleportedMap = ""
        TpButton.Text = "TP : ON"
        return
    end
    
    if not detectedMaps[targetMap] then detectedMaps[targetMap] = tick() end
    local timePassed = tick() - detectedMaps[targetMap]
    local timeLeft = math.max(0, math.ceil(11 - timePassed))
    
    if lastTeleportedMap ~= targetMap then
        TpButton.Text = "Waiting: " .. timeLeft .. "s (" .. targetMap .. ")"
    end
    
    if timePassed >= 11 and lastTeleportedMap ~= targetMap then
        lastTeleportedMap = targetMap
        TpButton.Text = "Teleporting..."
        
        if targetMap == "Factory" then safeTeleport(CFrame.new(-67, 289, 8995))
        elseif targetMap == "MilBase" then safeTeleport(CFrame.new(23, 201, 9193))
        elseif targetMap == "Bank2" then safeTeleport(CFrame.new(-40, 304, 8971))
        elseif targetMap == "Hotel" then safeTeleport(CFrame.new(10, 310, 8983))
        elseif targetMap == "House2" then safeTeleport(CFrame.new(60, 264, 9053))
        elseif targetMap == "ResearchFacility" then safeTeleport(CFrame.new(-103, 292, 8964))
        elseif targetMap == "Office3" then safeTeleport(CFrame.new(-92, 304, 9002))
        elseif targetMap == "PoliceStation" then safeTeleport(CFrame.new(58, 275, 9048))
        elseif targetMap == "Mansion2" then safeTeleport(CFrame.new(-35, 272, 8948)) 
        elseif targetMap == "Workplace" then safeTeleport(CFrame.new(71, 291, 8932))
        elseif targetMap == "BioLab" then safeTeleport(CFrame.new(566, 267, 9611))
        elseif targetMap == "Hospital" then safeTeleport(CFrame.new(-22, 284, 8942))
        end
    end
end

local function scanRolesAndInventory()
    local currentMurderer = nil
    local currentSheriff = nil
    
    for _, p in ipairs(Players:GetPlayers()) do
        pcall(function()
            local char = p.Character
            local bp = p:FindFirstChild("Backpack")
            
            local items = {}
            if char then for _, v in pairs(char:GetChildren()) do table.insert(items, v) end end
            if bp then for _, v in pairs(bp:GetChildren()) do table.insert(items, v) end end
            
            for _, item in pairs(items) do
                if item:IsA("Tool") then
                    if item.Name == "Knife" then
                        currentMurderer = p.Name
                        if reActive and p == LocalPlayer then
                            if char and char:FindFirstChild("Humanoid") then char.Humanoid.Health = 0 end
                        end
                    elseif item.Name == "Gun" then
                        currentSheriff = p.Name
                        if reActive and p == LocalPlayer then
                            if char and char:FindFirstChild("Humanoid") then char.Humanoid.Health = 0 end
                        end
                    end
                end
            end
        end)
    end
    
    if currentMurderer then
        MurdererLabel.Text = "MURDER: " .. string.upper(currentMurderer)
    else
        MurdererLabel.Text = "Murder: Scanning..."
    end
    
    if currentSheriff then
        SheriffLabel.Text = "SHERIFF: " .. string.upper(currentSheriff)
    else
        SheriffLabel.Text = "Sheriff: Scanning..."
    end
end

