-- SECURE LOGIC LOOPS
local function safeTeleport(coords)
    local c = LocalPlayer.Character
    if c then
        local r = c:FindFirstChild("HumanoidRootPart")
        if r then r.CFrame = coords * CFrame.new(math.random(-1,1)/10, 0, math.random(-1,1)/10) end
    end
end

local function executeTeleport()
    if not tpActive then return end
    local targetMap = nil
    local mapNames = {"Factory", "MilBase", "Bank2", "Hotel", "House2", "ResearchFacility", "Office3", "PoliceStation", "Mansion2", "Workplace", "BioLab", "Hospital"}
    for _, name in ipairs(mapNames) do if Workspace:FindFirstChild(name) then targetMap = name break end end
    
    if not targetMap then
        detectedMaps = {}
        lastTeleportedMap = ""
        TpButton.Text = "TP : ON"
        return
    end
    
    if not detectedMaps[targetMap] then detectedMaps[targetMap] = tick() end
    local timePassed = tick() - detectedMaps[targetMap]
    if lastTeleportedMap ~= targetMap then TpButton.Text = "Waiting: " .. math.max(0, math.ceil(12 - timePassed)) .. "s (" .. targetMap .. ")" end
    
    if timePassed >= 12 and lastTeleportedMap ~= targetMap then
        lastTeleportedMap = targetMap
        TpButton.Text = "Teleporting..."
        local targets = {["Factory"]=CFrame.new(-67,289,8995), ["MilBase"]=CFrame.new(23,201,9193), ["Bank2"]=CFrame.new(-40,304,8971), ["Hotel"]=CFrame.new(10,310,8983), ["House2"]=CFrame.new(60,264,9053), ["ResearchFacility"]=CFrame.new(-103,292,8964), ["Office3"]=CFrame.new(-92,304,9002), ["PoliceStation"]=CFrame.new(58,275,9048), ["Mansion2"]=CFrame.new(-35,272,8948), ["Workplace"]=CFrame.new(71,291,8932), ["BioLab"]=CFrame.new(566,267,9611), ["Hospital"]=CFrame.new(-22,284,8942)}
        if targets[targetMap] then safeTeleport(targets[targetMap]) end
    end
end

local function scanRolesAndInventory()
    local currentMurderer, currentSheriff = nil, nil
    for _, p in ipairs(Players:GetPlayers()) do
        pcall(function()
            local char, bp = p.Character, p:FindFirstChild("Backpack")
            local items = {}
            if char then for _, v in pairs(char:GetChildren()) do table.insert(items, v) end end
            if bp then for _, v in pairs(bp:GetChildren()) do table.insert(items, v) end end
            for _, item in pairs(items) do
                if item:IsA("Tool") then
                    if item.Name == "Knife" then currentMurderer = p.Name if reActive and p == LocalPlayer and char then char.Humanoid.Health = 0 end
                    elseif item.Name == "Gun" then currentSheriff = p.Name if reActive and p == LocalPlayer and char then char.Humanoid.Health = 0 end end
                end
            end
        end)
    end
    MurdererLabel.Text = currentMurderer and "MURDER: " .. string.upper(currentMurderer) or "Murder: Scanning..."
    SheriffLabel.Text = currentSheriff and "SHERIFF: " .. string.upper(currentSheriff) or "Sheriff: Scanning..."
end

